{
  "appId": "com.spetro.earn",
  "appName": "Spetro Earn",
  "webDir": "server/public",
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    },
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "url": "https://spetroearn.com",
    "androidScheme": "https",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#070f19",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
