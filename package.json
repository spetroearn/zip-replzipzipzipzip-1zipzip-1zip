{
  "name": "spetro-earn",
  "version": "1.0.0",
  "description": "Spetro Earn - Secure Reward Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "NODE_ENV=production node server/index.js",
    "deploy": "npm run build && NODE_ENV=production node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"vite build client --outDir ../server/public --watch\"",
    "build": "vite build client --outDir ../server/public",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "apk:setup": "bash scripts/setup-android.sh",
    "apk:sync": "bash scripts/sync-only.sh"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "nodemailer": "^8.0.8",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "vite": "^5.4.21"
  }
}
